{
  "expo": {
    "name": "Vygo",
    "slug": "camion-chiaro",
    "version": "0.1.0",
    "icon": "./assets/brand/icon.png",
    "orientation": "portrait",
    "scheme": "camionchiaro",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#ffffff",
      "image": "./assets/brand/splash-icon.png",
      "resizeMode": "contain"
    },
    "ios": {
      "buildNumber": "1",
      "bundleIdentifier": "it.camionchiaro.app",
      "supportsTablet": false,
      "config": {
        "usesNonExemptEncryption": false
      },
      "infoPlist": {
        "NSCameraUsageDescription": "Vygo usa la fotocamera per caricare documenti, guasti e allegati chat.",
        "NSLocalNetworkUsageDescription": "Vygo puo usare la rete locale solo durante le prove di sviluppo.",
        "NSMicrophoneUsageDescription": "Vygo usa il microfono per inviare messaggi vocali in chat.",
        "NSPhotoLibraryAddUsageDescription": "Vygo salva nella galleria le foto ricevute in chat quando lo chiedi.",
        "NSPhotoLibraryUsageDescription": "Vygo usa la galleria per allegare foto, video e documenti."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#12c6df",
        "foregroundImage": "./assets/brand/adaptive-icon.png"
      },
      "package": "it.camionchiaro.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-document-picker",
      "expo-image-picker",
      "expo-media-library",
      "expo-notifications",
      "expo-audio",
      [
        "expo-share-intent",
        {
          "iosActivationRules": {
            "NSExtensionActivationSupportsText": true,
            "NSExtensionActivationSupportsWebURLWithMaxCount": 1,
            "NSExtensionActivationSupportsWebPageWithMaxCount": 1,
            "NSExtensionActivationSupportsImageWithMaxCount": 10,
            "NSExtensionActivationSupportsMovieWithMaxCount": 5,
            "NSExtensionActivationSupportsFileWithMaxCount": 10
          },
          "iosShareExtensionName": "CamionChiaroShareExtension",
          "androidIntentFilters": [
            "text/*",
            "image/*",
            "video/*",
            "*/*"
          ],
          "androidMultiIntentFilters": [
            "image/*",
            "video/*",
            "*/*"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "6905bb3c-6a8d-469f-b2a7-284ab2a91c1b"
      }
    },
    "owner": "adrianosisti31",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/6905bb3c-6a8d-469f-b2a7-284ab2a91c1b"
    }
  }
}
