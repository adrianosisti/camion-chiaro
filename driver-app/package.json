{
  "name": "camion-chiaro-driver-app",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "expo run:android",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:preview": "npx eas-cli build --platform all --profile preview",
    "ios": "expo run:ios",
    "postinstall": "node scripts/patch-xcode-share-intent.cjs",
    "start": "expo start",
    "start:clear": "expo start --clear",
    "start:tunnel": "expo start --tunnel"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~54.0.0",
    "expo-audio": "~1.1.1",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-document-picker": "~14.0.8",
    "expo-file-system": "~19.0.23",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-media-library": "~18.2.1",
    "expo-notifications": "~0.32.17",
    "expo-share-intent": "^5.1.1",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "react": "^19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-url-polyfill": "latest"
  },
  "devDependencies": {
    "@babel/core": "latest",
    "@expo/ngrok": "^4.1.3",
    "babel-preset-expo": "~54.0.0"
